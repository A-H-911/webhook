SA_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
# Set to the ngrok public URL when using docker-compose.ngrok.yml,
# or the host IP/hostname for local-only deployments.
WEBHOOK_BASE_URL=http://your-server-hostname-or-ip
RETENTION_DAYS=7
MAX_REQUEST_SIZE_MB=5
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=CHANGE_ME_BEFORE_DEPLOY
AUTH_SESSION_HOURS=8

# ngrok tunnel — required when using docker-compose.ngrok.yml
NGROK_AUTHTOKEN=
