SA_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
# The public-facing base URL used to build webhook URLs shown in the UI.
# All existing tokens immediately reflect a change here after an API restart
# (the URL is computed at read time, not stored per-token in the database).
#
# Local-only (docker-compose without ngrok):
#   HOOKBIN_BASE_URL=http://localhost:8088
#
# Internet-accessible (docker-compose.ngrok.yml with static ngrok domain):
#   HOOKBIN_BASE_URL=https://your-domain.ngrok.app
#
# Direct dotnet run (development, no docker):
#   Set Webhook:BaseUrl in appsettings.Development.json (default: http://localhost:8080)
#   or export WEBHOOK__BaseUrl=http://localhost:8080 before running.
HOOKBIN_BASE_URL=http://localhost:8088
RETENTION_DAYS=7
MAX_REQUEST_SIZE_MB=5
# Max requests per second per token on the webhook receiver (default: 250, range: 1-10000)
WEBHOOK__ReceiverRateLimitPerSecond=250
AUTH_USERNAME=admin
# IMPORTANT: BCrypt hashes contain literal '$' characters that Docker Compose v2
# interprets as variable references. Escape every '$' as '$$' in this file.
# Generate with: dotnet run --project tools/RotatePassword -- --password 'YourPass'
# then replace each '$' with '$$' before pasting here.
# e.g.  $2b$12$abc... → $$2b$$12$$abc...
AUTH_PASSWORD_HASH=CHANGE_ME_BEFORE_DEPLOY
AUTH_SESSION_HOURS=8

# Stream worker consumer identity — stable across container restarts for PEL recovery.
# Only override in multi-replica scenarios; the compose default (stream-worker-1) is sufficient for single-instance.
# HOOKBIN_WORKER_ID=stream-worker-1

# ngrok tunnel — required when using docker-compose.ngrok.yml
NGROK_AUTHTOKEN=
