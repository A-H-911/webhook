{
  "env": {
    "ECC_OBSERVER_ALLOW_WINDOWS": "true",
    "ECC_OBSERVER_MAX_ANALYSIS_LINES": "30"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/scripts/guard.js\""
          }
        ]
      }
    ]
  }
}
