{
  "ConnectionStrings": {
    "WebhookDb": "Server=sqlserver;Database=WebhookDb;User Id=sa;Password=CHANGE_ME;TrustServerCertificate=True",
    "Redis": "redis:6379"
  },
  "Hookbin": {
    "RetentionDays": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
